# =============================================================================
#  FinalBot — Complete .env Configuration Template
#  All values here are defaults. Override any setting for your account/strategy.
# =============================================================================

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8636239659:PK3GFDMBHSO3JECT554MV3E3CO
TELEGRAM_CHAT_ID_TRADE_ALERTS_NEW=-1003713246101

# ── Alpaca Credentials (Account 1 — primary) ──────────────────────────────────
ALPACA_API_KEY=PK3GFDMBHSO3JECT554MV3E3CO
ALPACA_SECRET_KEY=2Q99yU7BWkCetTXi1BY8o3wYX6scsgBBLZkLgCE19D2X
ALPACA_ACCOUNT_NAME_1=account1

# ── Alpaca Credentials (Account 2 — optional second account) ──────────────────
ALPACA_API_KEY_2=PKAJVNEEA2HORKQ5J4VPHYB4RS
ALPACA_SECRET_KEY_2=FiwXCcNnLPGotPk1dVBc6LdxduNciC86M3VHpGgswJFm
ALPACA_ACCOUNT_NAME_2=account2

# ── Paper vs Live Trading ──────────────────────────────────────────────────────
BOT_PAPER=true

# ── Tickers (comma-separated) ─────────────────────────────────────────────────
BOT_TICKERS=ARM, TSLA, SMCI, DELL, NOW, SNOW, FIG, U, ORCL
# If true, the bot will NOT scan for new symbols or read Tanuki files. It will ONLY use BOT_TICKERS above.
BOT_TICKERS_ONLY_FROM_ENV=false
BOT_MAX_TICKER_DAILY_LOSSES=2
BOT_GLOBAL_TICKER_LOSS_LIMIT=true

# ── Data Feeds ────────────────────────────────────────────────────────────────
ALPACA_STOCK_DATA_FEED=iex
ALPACA_OPTION_DATA_FEED=indicative

# ── Dynamic Directional Bias (NEW) ──────────────────────────────────────────
# If true, the bot requires specific EMA200 alignment on 5m/10m charts.
# Enabling this can KILL momentum breakout trades.
BOT_DIRECTIONAL_BIAS_ENABLED=false


# Global fallbacks (used if an account has no override)
BOT_MAIN_QTY=5
BOT_SCALP_QTY=5

# Account 1 Override (e.g. your aggressive account)
ALPACA_ACCOUNT_NAME_1="Sridhar"
ACCOUNT_1_MAIN_QTY=5
ACCOUNT_1_SCALP_QTY=5

# Account 2 Override (e.g. your testing account)
ALPACA_ACCOUNT_NAME_2="Ganesh"
ACCOUNT_2_MAIN_QTY=5
ACCOUNT_2_SCALP_QTY=5

# ── Position Limits Per Account (per side) ────────────────────────────────────
MAX_OPEN_CALL_ORDERS=5
MAX_OPEN_PUT_ORDERS=5

# Per-account overrides (optional):
MAX_OPEN_CALL_ORDERS_Sridhar=5
MAX_OPEN_PUT_ORDERS_Sridhar=5

# Per-account overrides (optional):
MAX_OPEN_CALL_ORDERS_Ganesh=5
MAX_OPEN_PUT_ORDERS_Ganesh=5

# ── Dynamic Sizing & Daily Drawdown Limits ────────────────────────────────────
BOT_MAX_DRAWDOWN=2000
ACCOUNT_1_MAX_DRAWDOWN=4000.00
ACCOUNT_2_MAX_DRAWDOWN=2500.00


# ── Profit Targets ────────────────────────────────────────────────────────────
BOT_MAIN_TARGET_PCT=0.20
BOT_SCALP_TARGET_PCT=0.20

# ── Fast PnL Exit (NEW) ──────────────────────────────────────────────────────
BOT_FAST_EXIT_ENABLED=true
BOT_FAST_EXIT_PROFIT_PCT=0.20
BOT_FAST_EXIT_LOSS_PCT=0.25

# ── Trail Stop (Premium-Tracking Sell-Stop) ────────────────────────────────────
# Trail fires a market sell when: mark < peak_premium * BOT_TRAIL_CAPTURE_PCT
BOT_TRAIL_CAPTURE_PCT=0.80
# Trail only arms after option gains >= this % from entry (prevents early noise exits)
BOT_TRAIL_ACTIVATION_PCT=0.35
BOT_USE_DYNAMIC_TRAIL=false

# ── Hard Stop Loss ────────────────────────────────────────────────────────────
# Market sell fires immediately if mark drops >= this % below entry
BOT_STOP_LOSS_PCT=0.25

# ── Strike Grid & Search ──────────────────────────────────────────────────────
BOT_STRIKE_GRID=1.0
BOT_MAX_STRIKE_OFFSET=5.0
BOT_STRIKE_SEARCH_RANGE=10.0

#Dynamic Trailing Tiers
BOT_TRAIL_TIER1_GAIN=1.5
BOT_TRAIL_TIER1_CAPTURE=0.85
BOT_TRAIL_TIER2_GAIN=3.0
BOT_TRAIL_TIER2_CAPTURE=0.92

#Safeties and API Reliability
API_MAX_RETRIES=3
ALPACA_TIMEOUT_SEC=30
TELEGRAM_TIMEOUT_SEC=10
BOT_OUTAGE_POLL_LIMIT=3

BOT_MAX_SPREAD_PCT=0.4

# ── Time Windows (HH:MM format, Eastern Time) ─────────────────────────────────
BOT_NO_NEW_ENTRIES_BEFORE=09:35
BOT_NO_NEW_ENTRIES_AFTER=15:40
BOT_TERMINATE_AT=16:10
BOT_EOD_EXIT_TIME=15:50    # Force liquidate and stop at 3:50 PM ET (Options market close is 4 PM)
BOT_SCALP_WINDOW_START=09:35
BOT_SCALP_WINDOW_END=15:30

# ── Choppy Market Filter ──────────────────────────────────────────────────────
# Minimum ADX value to consider the market trending (not choppy)
# If you want the bot to aggressively fire off trades more often,reduce the numbers
# But we may see false breakouts
BOT_ADX_MIN_THRESHOLD=18.0

# Minimum ADX/DI cross count required before taking a signal
BOT_ADX_CROSS_COUNT_MIN=3

# ── RSI Signal Thresholds ─────────────────────────────────────────────────────
BOT_RSI_BULL_THRESHOLD=45.0
BOT_RSI_BEAR_THRESHOLD=55.0

# ── Historical Data Lookback Windows ─────────────────────────────────────────
BOT_LOOKBACK_5M_DAYS=5
BOT_LOOKBACK_1M_DAYS=5
BOT_LOOKBACK_10M_DAYS=10

# ── Order Management ──────────────────────────────────────────────────────────
BOT_FILL_TIMEOUT_SEC=45
BOT_POLL_INTERVAL_SECONDS=15

BOT_RVOL_THRESHOLD=1.2
BOT_PULLBACK_PERCENT=1.5

# No new trades window. Existing trades will be handled through trailing loss logic
BOT_BLACKOUT_WINDOWS="2026-04-01 14:00-15:00, 2026-04-03 09:30-10:00"

BOT_MAX_DIN_FOR_CALL=10              # Block CALL if any DI- cross (allow up to 2)
BOT_MAX_DIP_FOR_PUT=3               # Block PUT if DI+ crosses > this
BOT_MIN_BREAKOUT=0.15               # Minimum price breakout above prev_high for CALL
BOT_MIN_PREMIUM=0.15                # Global minimum option premium
BOT_INDEX_MIN_PREMIUM=0.15          # Min premium for QQQ/IWM/SPY specifically
BOT_INDEX_TICKERS=QQQ,IWM,SPY       # Which tickers use the index premium floor
BOT_SCALP_WINDOW_END=15:40          # Hard gate: no new scalps after 2:30 PM

# ── DI- Cross Confirmation for PUT (Filter 4) ─────────────────────────────────
# Only tickers listed in BOT_DIN_PUT_FILTER_TICKERS will require a minimum
# number of DI- crosses before a PUT scalp signal is accepted.  High-momentum
# directional names (e.g. TSLA, MSTR, COIN) should be LEFT OUT of this list
# so they can still fire PUT signals without a prior DI- cross confirmation.
# Choppy index ETFs (QQQ, IWM, SPY) benefit most from this filter.
BOT_DIN_PUT_FILTER_TICKERS=QQQ,IWM,SPY   # tickers that must satisfy Filter 4
BOT_MIN_DIN_FOR_PUT=1                     # min ADXDInT crosses required (for tagged tickers only)

# How many polls to wait before assuming a missing position was manually closed (default: 3)
BOT_POSITION_SYNC_LIMIT=3

# The divider for wide-spread limit orders (default: 5.0)
# BID + (SPREAD / 2.0) is more likely to fill than SPREAD / 5.0
BOT_WIDE_SPREAD_DIVIDER=2
BOT_KELLY_MULTIPLIER=0.25


GITHUB_CONFIG_URL=https://github.com/bhawish01/Limit/blob/main/config.json
STRIKE_LIMITS_URL=https://github.com/bhawish01/Limit/blob/main/strike_limits.json

# ── Market Discovery Scanner (NEW) ───────────────────────────────────────────
# Automatically adds top movers to the watchlist in real-time.
BOT_DISCOVERY_ENABLED=true
# Minimum daily % gain (e.g. 5.0)
BOT_DISCOVERY_MIN_GAIN=0.1
# Minimum daily volume (e.g. 500,000)
BOT_DISCOVERY_MIN_VOLUME=50000
# Price Floor/Ceiling for discovered stocks
BOT_DISCOVERY_MIN_PRICE=15.0
BOT_DISCOVERY_MAX_PRICE=500.0
# Max candidates to add to monitor list per scan
BOT_DISCOVERY_MAX_COUNT=10
# How often to scan (minutes)
BOT_DISCOVERY_INTERVAL_MIN=15

BOT_DISCOVERY_ENABLED=true

# --- Account 1 Specific Guards ---
ACCOUNT_1_MAX_OPTION_PRICE=5.50

# Quantity tiers based on premium price:
ACCOUNT_1_QTY_LT1=10   # Qty when price < 1.00
ACCOUNT_1_QTY_1TO2=5  # Qty when price 1.00 - 2.00
ACCOUNT_1_QTY_2TO3=4  # Qty when price 2.00 - 3.00
ACCOUNT_1_QTY_3TO4=3   # Qty when price 3.00 - 4.00
ACCOUNT_1_QTY_4TO5=2   # Qty when price 4.00 - 5.00
ACCOUNT_1_QTY_GT5=1    # Qty when price > 5.00

# --- Account 1 Specific Guards ---
ACCOUNT_2_MAX_OPTION_PRICE=5.50

# Quantity tiers based on premium price:
ACCOUNT_2_QTY_LT1=10   # Qty when price < 1.00
ACCOUNT_2_QTY_1TO2=5  # Qty when price 1.00 - 2.00
ACCOUNT_2_QTY_2TO3=4  # Qty when price 2.00 - 3.00
ACCOUNT_2_QTY_3TO4=3   # Qty when price 3.00 - 4.00
ACCOUNT_2_QTY_4TO5=2   # Qty when price 4.00 - 5.00
ACCOUNT_2_QTY_GT5=1    # Qty when price > 5.00

BOT_RSI_MAX_OVERBOUGHT=60.0
BOT_RSI_MIN_OVERSOLD=25.0
BOT_EMA_STRETCH_PCT=1.5


# Alignment
# (Implicitly enabled via core code)

# Volatility Stops (ATR)
BOT_USE_ATR_TRAIL=true        # Change to true to enable ATR-based trailing
BOT_ATR_STOP_MULTIPLIER=4.0    # How many ATRs of "breathing room" to allow

# Volatility Filter (IV)
BOT_MAX_ENTRY_IV=2.0           # Block entries if IV > 300%
BOT_IV_MOMENTUM_ENABLED=true   # Phase 3: Require rising IV for Calls, falling IV for Puts


BOT_MAX_STRIKE_OFFSET=10
# BOT_RSI thresholds are defined above
BOT_EMA_SPREAD_MIN_PCT=0.0
BOT_MIN_HOLD_MINUTES=10
BOT_REENTRY_COOLDOWN_MIN=10

BOT_MAX_CONTRACTS=10
BOT_MAX_ORDER_VALUE=2000

# ── IV Rank (IVR) Filter ──────────────────────────────────────────────────────
BOT_MAX_IVR=50.0

# Sample 52-week IV ranges (IV Low - IV High)
# These should be updated periodically or based on your preferred IV source.
#BOT_IV_LOW_QQQ=0.10
#BOT_IV_HIGH_QQQ=0.40
#BOT_IV_LOW_SPY=0.08
#BOT_IV_HIGH_SPY=0.35
#BOT_IV_LOW_TSLA=0.40
#BOT_IV_HIGH_TSLA=1.20

# ── Order Book Imbalance (OBI) Filter ─────────────────────────────────────────
#BOT_OBI_BULL_THRESHOLD=0.0
#BOT_OBI_BEAR_THRESHOLD=0.0

# ── VIX-Based Position Sizing ────────────────────────────────────────────────
BOT_VIX_LOW=15.0       # Scaled up to 1.5x below this
BOT_VIX_HIGH=29.0      # Halved exposure (0.5x) above this
BOT_VIX_EXTREME=35.0   # Quarter size (0.25x) above this

# ── VWAP SD Bands Filter ────────────────────────────────────────────────────
# When true, entries are only allowed near VWAP +/- 1 SD (accumulation zones)
# rather than chasing momentum far from VWAP.
BOT_VWAP_BAND_ENTRY=true
BOT_REQUIRE_15M_ALIGNMENT=true
BOT_MARKET_ALIGNMENT_ENABLED=false
BOT_EMA_SPREAD_MIN_PCT=0.0

# ── Unusual Options Flow (Dark Pool) Detection ──────────────────────────────
# When enabled, the bot scans the option chain for strikes where today's 
# volume is significantly higher than yesterday's open interest (OI).
# A threshold of 3.0 means volume is 3x higher than OI.
BOT_TRACK_OPTION_FLOW=true
BOT_UNUSUAL_OI_THRESHOLD=2.0


# Minimum Relative Volume on 5m chart for entries (e.g. 1.2 = 20% higher than prior 5 bars avg). 0.0 turns it off.
BOT_5M_RVOL_THRESHOLD=0.0

# Quantity of butterfly contracts for GexButterflyBot
GEX_BOT_QTY=1

BOT_DISCOVERY_MIN_VOL_RANGE=0.01

BOT_DISCOVERY_OUTPUT_FILE=c:\Temp\Perp\TradingBot\discovered_tickers.json
TANUKI_SCAN_RESULTS_FILE=c:\Temp\Tanuki\scan_results.json

BOT_DISCOVERY_MAX_TICKERS=15
BOT_DISCOVERY_MAX_COUNT=15

BOT_MAX_DELTA_CALL=0.95
BOT_MAX_DELTA_PUT=0.90

