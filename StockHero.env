# --- Live Trading Override ---
# Set to TRUE to place REAL trades regardless of market hours (for end-to-end testing).
# WARNING: Real orders will be placed even outside 9:30 AM - 4:01 PM EST.
# Set to FALSE or comment out to enforce the normal trading window.
FORCE_LIVE_TRADING=TRUE

